# Set real key in .env (or .env.local). Do NOT commit secrets.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
WHISPER_MODEL=small
WHISPER_LANGUAGE=auto
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0.0
WHISPER_CHUNK_SEC=60
WHISPER_OVERLAP_SEC=8
WHISPER_PARALLEL_WORKERS=3
MIN_CORNER_SEC=20
MERGE_GAP_SEC=2
DATABASE_URL=sqlite:///./app/data/video_analyzer.db
